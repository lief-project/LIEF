#ifndef LIEF_RUNTIME_CONFIG_H
#define LIEF_RUNTIME_CONFIG_H

#cmakedefine LIEF_RUNTIME_PLATFORM_LINUX @LIEF_RUNTIME_PLATFORM_LINUX@
#cmakedefine LIEF_RUNTIME_PLATFORM_WINDOWS @LIEF_RUNTIME_PLATFORM_WINDOWS@
#cmakedefine LIEF_RUNTIME_PLATFORM_ANDROID @LIEF_RUNTIME_PLATFORM_ANDROID@
#cmakedefine LIEF_RUNTIME_PLATFORM_OSX @LIEF_RUNTIME_PLATFORM_OSX@
#cmakedefine LIEF_RUNTIME_PLATFORM_IOS @LIEF_RUNTIME_PLATFORM_IOS@

#cmakedefine LIEF_RUNTIME_ARCH_ARM64 @LIEF_RUNTIME_ARCH_ARM64@
#cmakedefine LIEF_RUNTIME_ARCH_X86_64 @LIEF_RUNTIME_ARCH_X86_64@


#ifdef __cplusplus
namespace LIEF {
namespace runtime {
static constexpr bool platform_linux = @LIEF_RUNTIME_PLATFORM_LINUX@;
static constexpr bool platform_windows = @LIEF_RUNTIME_PLATFORM_WINDOWS@;
static constexpr bool platform_android = @LIEF_RUNTIME_PLATFORM_ANDROID@;
static constexpr bool platform_osx = @LIEF_RUNTIME_PLATFORM_OSX@;
static constexpr bool platform_ios = @LIEF_RUNTIME_PLATFORM_IOS@;

static constexpr bool arch_arm64 = @LIEF_RUNTIME_ARCH_ARM64@;
static constexpr bool arch_x86_64 = @LIEF_RUNTIME_ARCH_X86_64@;

}
}
#endif // __cplusplus

#endif
